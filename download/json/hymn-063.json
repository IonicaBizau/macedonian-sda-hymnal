{
    "songNumber": 63,
    "title": "О, главо крунисана",
    "verses": [
        {
            "content": {
                "lines": [
                    "О главо крунисана,",
                    "Што светот ти се смеј,",
                    "О главо полна с рани,",
                    "Ти имаш трнлив сплет.",
                    "Од чело твое тече,",
                    "Во маки крв и пот,",
                    "За тебе сега мислам,",
                    "Ти прими поздрав мој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "За бол и маки твои,",
                    "О јас сум само крив,",
                    "А ти си зарад' мене",
                    "На крстот распнат жив.",
                    "А јас се кајам сега,",
                    "Од цело срце, знај,",
                    "Прости ми, Христе, Спасе,",
                    "Ти прости ми за сè."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ти благодарам, Спасе,",
                    "Што страдаше в тој час,",
                    "Знам смртта твоја даде,",
                    "За мене вечен спас.",
                    "Дај ми да навек гледам,",
                    "Во трнлив венец твој,",
                    "На крстот тебе, Спасе,",
                    "Низ сиот живот мој."
                ],
                "refrain": false
            }
        }
    ]
}