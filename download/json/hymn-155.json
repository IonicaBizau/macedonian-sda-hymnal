{
    "songNumber": 155,
    "title": "Против искушение",
    "verses": [
        {
            "content": {
                "lines": [
                    "Против искушење",
                    "Храбро бори се,",
                    "Да те не победи,",
                    "Збери силите.",
                    "Гледај ти во Спасот",
                    "Штом ќе почне бој,",
                    "И по Зборот Божји,",
                    "Како стена стој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Немој грев да те свлада,",
                    "Моќта твоја е Спасот,",
                    "Ќе ти помогне тебе,",
                    "Храбро бори се ти."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Бегај од зло друштво",
                    "Верен биди му,",
                    "Срцето го чувај,",
                    "Чувај се од зло.",
                    "Ти го слушај Спасот,",
                    "Прашај го за сè,",
                    "Знај во права радост,",
                    "Бог те води твој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Немој да се плашиш,",
                    "Само храбро стој,",
                    "Ти во Спасот гледај,",
                    "Чувај венец свој.",
                    "Свиден дар ти готви,",
                    "Горе Господ твој,",
                    "Гревој ако свладаш,",
                    "Ќе те дари Тој."
                ],
                "refrain": false
            }
        }
    ]
}