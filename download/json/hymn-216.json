{
    "songNumber": 216,
    "title": "Силно свети милост Божја",
    "verses": [
        {
            "content": {
                "lines": [
                    "Силно свети милост Божја,",
                    "Цела земја е во сјај.",
                    "Животот наш нека свети",
                    "Како жижок в секој крај."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Нека горат светилници,",
                    "Нека пливат в силен сјај,",
                    "Нека уште многу в ноќта",
                    "Најдат пат за вечен рај."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Бурно море животот е,",
                    "Сегде цари грев и мрак,",
                    "И во стравот многу велат:",
                    "На светилник кај е зрак?"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Нека гори светлост ваша,",
                    "Еден бродар бара спас,",
                    "Можда гине што не гледа",
                    "Жижок ваш во овој час."
                ],
                "refrain": false
            }
        }
    ]
}