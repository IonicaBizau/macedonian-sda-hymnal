{
    "songNumber": 49,
    "title": "Тој ден е полн со среќа",
    "verses": [
        {
            "content": {
                "lines": [
                    "О колку јас сум радосен",
                    "Штом ден Господен дојде.",
                    "Тој ден е в слава овенчан,",
                    "И сиот јад ни пројде."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "(:Тој ден е полн со среќа,:)",
                    "Што ни носи тој Божји",
                    "Збор во наш дом,",
                    "Тој ден полн е Божја слава."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Во Зборот Божји извор е",
                    "Што тече жива вода.",
                    "Ни дава храна Исус нам",
                    "И лек на срце става."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Во домот Божји добро е,",
                    "На сите ни е мило.",
                    "На земја овде никаде,",
                    "Поарно не би било."
                ],
                "refrain": false
            }
        }
    ]
}