    "songNumber": 17,
    "title": "О Боже, Творче мој",
    "verses": [
        {
            "content": {
                "lines": [
                    "О Боже, Творче мој,",
                    "Од тебе имам сè.",
                    "(:И секој ден ми даваш ти,",
                    "О дарој небесни.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ти си ме создал, знам,",
                    "И чуваш живот мој.",
                    "(:Со љубов си ме водел ти,",
                    "Од зло во народ свој.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Со својта љубов ти,",
                    "Обнови живот мој.",
                    "(:Со силата на Духот свој,",
                    "Да бидам вечно твој.:)"
                ],
                "refrain": false
            }
        }
    ]
