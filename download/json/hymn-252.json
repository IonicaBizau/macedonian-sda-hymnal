{
    "songNumber": 252,
    "title": "Свежа бистра вода",
    "verses": [
        {
            "content": {
                "lines": [
                    "Свежа, бистра вода",
                    "В бистар извор свој,",
                    "Како кристал чиста,",
                    "Нам ни даде Бог.",
                    "Сегде вода тече,",
                    "Сегде в земјин шир,",
                    "Носи нова сила",
                    "И блажен Божји мир."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Водо, водо,",
                    "ти си наша сласт,",
                    "Бог те за нас даде,",
                    "Нему слава чест."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Нежно цвеќе расте",
                    "Што ни даде Бог,",
                    "Поле се румени",
                    "И носи свој род.",
                    "Кај што суша гори,",
                    "Вене, тажи сè,",
                    "Сета радост гине",
                    "И живот мртов е."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Кој што вино бара",
                    "Покрај водна сласт,",
                    "Здравје тој си губи,",
                    "Сека надеж, власт.",
                    "И во маки паѓа",
                    "Кој е негов роб,",
                    "И на крајот оди",
                    "Во беда и во гроб."
                ],
                "refrain": false
            }
        }
    ]
}