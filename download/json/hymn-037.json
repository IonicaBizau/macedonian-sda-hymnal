{
    "songNumber": 37,
    "title": "Теб' Tе, Боже, фалиме",
    "verses": [
        {
            "content": {
                "lines": [
                    "Теб' те, Боже, фалиме",
                    "Во тој свет саботен ден,",
                    "Народот те слави твој,",
                    "Со срце благодарно.",
                    "Славете го в негов храм,",
                    "Полн е вечна милост, знам,",
                    "Грев да прости сака Тој,",
                    "И нè води в домот свој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Секој слава да ти пеј,",
                    "Срце да ти предаде,",
                    "О ти, Боже, славен си,",
                    "Народ свој ти погледај.",
                    "Да сме едно во тебе,",
                    "Кажи ни со Зборот свој,",
                    "Кој е пат за домот твој",
                    "Кажи ни со Зборот свој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Нека твојот свети Збор",
                    "Ги освети срцата,",
                    "С Духот твој нè учи ти,",
                    "Да сме полни родови.",
                    "Дај на сите живот нов",
                    "И свој свети благослов,",
                    "А штом дојде денот твој",
                    "Води нè во домот свој."
                ],
                "refrain": false
            }
        }
    ]
}