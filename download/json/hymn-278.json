{
    "songNumber": 278,
    "title": "Чуј о, чуј му глас",
    "verses": [
        {
            "content": {
                "lines": [
                    "О ти, солзи истриј,",
                    "Чуј, о чуј му глас,",
                    "Грижа ти да немаш,",
                    "Знај, сè гледа Спас.",
                    "Ти за сè му кажи,",
                    "Ќе те чуе Тој,",
                    "Сила ќе ти даде",
                    "Да издржиш сè."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Секому што страда,",
                    "И го мори јад,",
                    "Кажи му за Христа,",
                    "Надеж дава Тој.",
                    "Со нив ти се моли,",
                    "Дигни својот глас,",
                    "Бог за маки знае,",
                    "Ќе ви даде спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Скоро мир ќе дојде,",
                    "Мир и одмор твој,",
                    "Кога Исус дојде",
                    "Лут ќе мине бој.",
                    "Немој да се грижиш,",
                    "Ќе те чува Спас,",
                    "Еве веќе иде,",
                    "Да нè спаси нас."
                ],
                "refrain": false
            }
        }
    ]
}