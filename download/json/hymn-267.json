{
    "songNumber": 267,
    "title": "Како ѕвезди ќе светат",
    "verses": [
        {
            "content": {
                "lines": [
                    "Кога Исус, кога Исус",
                    "Ќе дојде ко цар,",
                    "Ќе нè води таму в небо",
                    "Во најголем дар."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Како ѕвезди ќе светат",
                    "Сите спасени.",
                    "Венци Тој ќе ни даде",
                    "И златен свој Град."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Сите деца ќе ги води",
                    "Тој за раце сам,",
                    "Таму има рајска бавча",
                    "И блаженство знам."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Затоа му срце дајте",
                    "И свој живот млад,",
                    "Сигурно нè Исус води",
                    "В небесниот Град."
                ],
                "refrain": false
            }
        }
    ]
}