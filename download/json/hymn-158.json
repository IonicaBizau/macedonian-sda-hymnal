{
    "songNumber": 158,
    "title": "На вечната стена ние ѕидаме",
    "verses": [
        {
            "content": {
                "lines": [
                    "На вечната стена ѕидаме,",
                    "На стената Исус Христос,",
                    "И во неа само гледаме,",
                    "Во таа вечна стена."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "(:Ние ѕидаме,:)",
                    "На вечната стена се ѕидаме,",
                    "На законот Христов."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Кој ѕида на лажно богатство,",
                    "На слава и чест од други,",
                    "Штом ќе дојде бура на тој дом,",
                    "Без тресок тој ќе падне."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О дојдете сите, ѕидајте",
                    "На правата Божја стена,",
                    "И во неа само гледајте,",
                    "Од неа живот тече."
                ],
                "refrain": false
            }
        }
    ]
}