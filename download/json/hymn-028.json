{
    "songNumber": 28,
    "title": "Читај го читај Светото Писмо",
    "verses": [
        {
            "content": {
                "lines": [
                    "Читај го читај, Светото писмо,",
                    "Барај го Спасот во него,",
                    "Правата мудрост да ја најдеш,",
                    "Проучи ја Библијата."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Читај ја ти, о Бог ти вели,",
                    "Читај ја ти и моли се,",
                    "Чукај на Божја врата сега,",
                    "Тој да ти прости гревојте."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Читај го читај, Светото писмо,",
                    "Оди по патот Божји прав,",
                    "Во вечен живот ти ќе дојдеш,",
                    "Верувај што ти вели Бог."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Читај го читај, Светото писмо,",
                    "За патот прав нè учи нас,",
                    "Чини што вели Светото писмо",
                    "Од него збори Божји глас."
                ],
                "refrain": false
            }
        }
    ]
}