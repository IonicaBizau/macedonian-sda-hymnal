{
    "songNumber": 329,
    "title": "Благородни спомени",
    "verses": [
        {
            "content": {
                "lines": [
                    "Не ми збори жални зборој,",
                    "Како сон е животот,",
                    "Што се гледа, сè е лажно,",
                    "Кои спијат, мртви се."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Своја цел животот има,",
                    "Важна со значение,",
                    "Работа за тебе има,",
                    "Работа и за мене."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Секој век си имал борци,",
                    "Смели, добри, работни,",
                    "Да оставиме и ние,",
                    "Благородни спомени."
                ],
                "refrain": false
            }
        }
    ]
