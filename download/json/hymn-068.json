{
    "songNumber": 68,
    "title": "Песна света",
    "verses": [
        {
            "content": {
                "lines": [
                    "Ни харфиниот звук,",
                    "Ни песна с весел глас,",
                    "Не звучи како зборот “Исус”.",
                    "И кога в страшен вик,",
                    "Од бури трепти свет,",
                    "О слатко звучи зборот “Исус”."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Песна света,",
                    "В небо лета,",
                    "Го слави тоа име “Исус”.",
                    "Песна света, в небо лета,",
                    "Го слават својот Спас."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "За народ Божји свет,",
                    "Тој глас е толку мил,",
                    "О тоа свето име “Исус”.",
                    "Ко нежен и бел цвет,",
                    "Што има мирис благ,",
                    "О така мил е зборот “Исус”."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "И в срце ми е рај",
                    "Штом умре лично “јас”,",
                    "А тогаш жив е само Исус.",
                    "На гревот иде крај",
                    "И живот нов е, знај,",
                    "Нам светлост ни е само Исус."
                ],
                "refrain": false
            }
        }
    ]
}