{
    "songNumber": 35,
    "title": "Кога гасне сончев зрак",
    "verses": [
        {
            "content": {
                "lines": [
                    "Кога гасне сончев зрак,",
                    "И на земја падне мрак,",
                    "Тогаш расте ѕвезден рој,",
                    "Тогаш иде денот твој,",
                    "О Боже мој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Слава, слава, слава, на Творецот!",
                    "Теб' те слави ѕвезден рој,",
                    "Теб' те слави семир твој,",
                    "О Боже наш."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Во тој свети мили час,",
                    "Збираш нè кај себе нас,",
                    "Твојот дом е славен, знам,",
                    "Готви ме за вечен рај,",
                    "О Господе."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Штом задниот мине бој,",
                    "Ќе ти пеам славопој,",
                    "Среде рајска слава пој,",
                    "В таа вечна сабота,",
                    "О Спасе мој."
                ],
                "refrain": false
            }
        }
    ]
}