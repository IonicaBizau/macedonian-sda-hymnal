{
    "songNumber": 205,
    "title": "Станујте ноќ ќе дојде",
    "verses": [
        {
            "content": {
                "lines": [
                    "Станујте, ноќ ќе дојде,",
                    "Станујте, зора е.",
                    "Брзај од рано утро",
                    "Ноќта доаѓа.",
                    "Додека Сонце свети,",
                    "Секој да работи.",
                    "Бргу ќе дојде ноќта,",
                    "Сè ќе престане."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Станујте, ноќ ќе дојде,",
                    "Ни малку не стојте.",
                    "Силите свој на Бога",
                    "Посветете ги.",
                    "Брзај со цело срце,",
                    "Работи вредно ти.",
                    "Бргу ќе дојде ноќта,",
                    "Сè ќе престане."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Станујте, ноќ ќе дојде,",
                    "Стануј, на работа.",
                    "Макар да вечер паѓа,",
                    "Ти пак работи.",
                    "Кога се сонце гаси",
                    "Ти вредно работи.",
                    "Бргу се ноќта спушта,",
                    "Милост минува."
                ],
                "refrain": false
            }
        }
    ]
}