{
    "songNumber": 245,
    "title": "Бог е добар",
    "verses": [
        {
            "content": {
                "lines": [
                    "“Бог е добар!” - с' ори глас,",
                    "Тој нè учи, наш е Спас.",
                    "“Бог е добар!” - цвеќе пеј,",
                    "А јас пеам славопој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "(:Добар Бог!:) - нек се ори:",
                    "“Добар Бог!”",
                    "(:Добар Бог!:) - сè го слави",
                    "Творецот."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "“Бог е добар!” - птичји глас",
                    "Во утро нè буди нас.",
                    "“Бог е добар!” - поток леј,",
                    "Од брег песна тој ни пеј."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "“Бог е добар!” - ѕвезди рој,",
                    "Поздрав праќа ваму тој.",
                    "“Бог е добар!” - в сончев зрак,",
                    "Блиста тој штом мине мрак."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "“Бог е добар!” - наш е Спас,",
                    "В детски грла ечи глас.",
                    "“Бог е добар!” - грижи се,",
                    "Затоа го слави сè."
                ],
                "refrain": false
            }
        }
    ]
}