{
    "songNumber": 247,
    "title": "Сите добри дарој",
    "verses": [
        {
            "content": {
                "lines": [
                    "Рамнини а и гори,",
                    "Убавини в небо;",
                    "Езера, реки, море:",
                    "Сè створи мили Бог."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Сите добри дарој",
                    "Од Бога нам ни се,",
                    "(:Од красно сино небо наше.:)"
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "На сонце зраци дава,",
                    "Тој праќа месец блед,",
                    "И води јаки бури,",
                    "Тој прави снег и лед."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Бог праќа дожд и роса,",
                    "И златен сончев сјај,",
                    "Да носи свој род поле",
                    "И цвета вечно рај."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Тој створи шуми, цвеќе,",
                    "И нам ни даде дом,",
                    "И рано утро, вечер,",
                    "Тој створи молња, гром."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Бог нам ни радост дава,",
                    "Добрини голем број,",
                    "За стока дава трева",
                    "И леб на народ свој."
                ],
                "refrain": false
            }
        }
    ]
}