{
    "songNumber": 137,
    "title": "Денес те вика Твој Спасител нежно",
    "verses": [
        {
            "content": {
                "lines": [
                    "Денес те вика твој Спасител нежно,",
                    "Везден се моли за нас,",
                    "Чека да фрлиме окови грешни,",
                    "Дојди и прими свој спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Чуј глас, чуј глас,",
                    "Дојди ти кај својот Спас.",
                    "Денес те вика твој Спасител нежно,",
                    "Дојди, о дојди сега."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Зошто ти чекаш и одбиваш милост,",
                    "Погледај, заден е час?",
                    "Исус те вика, ти срце му даруј,",
                    "Прими го, Тој е твој Спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Христос ти проштава и с љубов прима,",
                    "Милост ти дарува Тој,",
                    "Сака за навек и теб' да те спаси,",
                    "Дојди кај Спасителот."
                ],
                "refrain": false
            }
        }
    ]
}