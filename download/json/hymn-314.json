{
    "songNumber": 314,
    "title": "Вика Тој, о, доди ти",
    "verses": [
        {
            "content": {
                "lines": [
                    "С љубов прима Исус Спас",
                    "Душа од грев ранета.",
                    "С нежен глас ти проштава,",
                    "В своја милост голема."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "(:Вика Тој: “О дојди ти!”,",
                    "Добар е и милостив.:)"
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "С радост прима Исус Спас",
                    "Души уморни од грев.",
                    "Терет твој и маки знај,",
                    "Вечна љубов Таткова."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Тој ги прима грешните",
                    "Кој од грев се жалосни.",
                    "Да не грешиш храбри Тој,",
                    "Слушај му ги зборојте."
                ],
                "refrain": false
            }
        }
    ]
}