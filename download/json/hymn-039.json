{
    "songNumber": 39,
    "title": "Слободни од сите грижи",
    "verses": [
        {
            "content": {
                "lines": [
                    "И на работа и по пат,",
                    "Пеам песни сионски.",
                    "И од сите најарни се",
                    "Тие песни саботни."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Слободни од сите грижи",
                    "Ние сме во сабота,",
                    "Срцата со радост полни,",
                    "Теб' те слават, Боже наш."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Серафими Бога слават,",
                    "Славен е на престолот.",
                    "Овде сега пак и ние",
                    "Радосно го славиме."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Боже, тебе ќе ти пеам",
                    "Овде в сиот живот мој,",
                    "И на небо еднаш вечно",
                    "Јас да бидам само твој."
                ],
                "refrain": false
            }
        }
    ]
}