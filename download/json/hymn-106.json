{
    "songNumber": 106,
    "title": "Сионе, ти мил и убав",
    "verses": [
        {
            "content": {
                "lines": [
                    "Сионе, ти мил и убав,",
                    "С блаженство полн си ти,",
                    "В рането срце ми носиш",
                    "Мелем за маките."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Сионе, ти мил и убав,",
                    "Брзам јас во твој дом,",
                    "О за тебе пеам и мислам,",
                    "За блаженство и твој мир."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Срцето ми долго тежи",
                    "За тебе, Сионе,",
                    "Води ме скоро кај себе,",
                    "Во Сион, Господе."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Таму е престолот свети,",
                    "Таму е мојот Спас,",
                    "Нова се песна пеј, ори,",
                    "Сè слави Господа."
                ],
                "refrain": false
            }
        }
    ]
}