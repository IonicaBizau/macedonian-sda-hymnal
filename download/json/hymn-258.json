{
    "songNumber": 258,
    "title": "В срцето да ни е радост",
    "verses": [
        {
            "content": {
                "lines": [
                    "В срцето да ни е радост",
                    "И благодарност вечна,",
                    "Што нè Таткото наш вика,",
                    "Да сме деца негови."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Везден радост, везден радост,",
                    "В секој ден е сончев сјај,",
                    "Патот ни е полн со Божја слава,",
                    "Радост води срца в рај."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Божја рака нас нè води",
                    "И во бој нè брани нас,",
                    "Секој ден ни милост дава,",
                    "Готви нè за вечен спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Праведните напред одат,",
                    "По патот на правдата,",
                    "Кој на Христа верно служи,",
                    "В славата ќе влезе Тој."
                ],
                "refrain": false
            }
        }
    ]
}