{
    "songNumber": 332,
    "title": "О, чедо дојди ти",
    "verses": [
        {
            "content": {
                "lines": [
                    "Штом ме Исус тивко викне:",
                    "“О чедо, дојди ти!”",
                    "Во тој позив радост трепне,",
                    "Слатка музика ми шепне:",
                    "О дојди ти, о дојди ти, чедо, о дојди ти."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Бегај од гревојте страшни,",
                    "О чедо, бегај ти.",
                    "Секој којшто бара помош",
                    "Нема празен да се врати,",
                    "О дојди ти, о дојди ти, чедо, о дојди ти."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Сега в тие дни на младост,",
                    "О чедо, дојди ти,",
                    "И со срце полно радост",
                    "Тргни по патот на светост,",
                    "О дојди ти, о дојди ти, чедо, о дојди ти."
                ],
                "refrain": false
            }
        }
    ]
}