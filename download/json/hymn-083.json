{
    "songNumber": 83,
    "title": "Славно име, Исус",
    "verses": [
        {
            "content": {
                "lines": [
                    "Име изнад секо друго",
                    "Даде Бог на својот Син,",
                    "Тој да биде живот вечен,",
                    "Патот за небесен дом."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Славно име, Исус,",
                    "Тоа мило име,",
                    "Тоа лице нам ни го прати Бог.",
                    "Тој од смрт нè спаси,",
                    "Тоа име славно,",
                    "Спасител наш, мили Исус."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Тој е благослов, дар свети,",
                    "Вечно ќе го славам јас,",
                    "Тој ми дава надеж, сила,",
                    "Милостив е в секој час."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Пејте сите, пејте слава,",
                    "Пејте му на Спасот свој,",
                    "Зашто животот е в него",
                    "И спасение од зло."
                ],
                "refrain": false
            }
        }
    ]
}