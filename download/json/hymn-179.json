{
    "songNumber": 179,
    "title": "Глеј, ангел Божји лета",
    "verses": [
        {
            "content": {
                "lines": [
                    "Глеј, ангел Божји лета",
                    "Низ земја в секој крај,",
                    "Тој да нè теши в грижи,",
                    "(:О Бог го прати, знај.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Од око мир му зрачи",
                    "И милост за цел род,",
                    "О појди ти со него",
                    "(:За спас нè учи Тој.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Тој навек верно води",
                    "Низ секој земни крај,",
                    "И тивко Тој ни збори,",
                    "(:Да ни е близу рај.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Штом беда ќе те стигне,",
                    "Те теши тогаш Тој,",
                    "Со тебе твој крст носи,",
                    "(:И добро прави сè.:)"
                ],
                "refrain": false
            }
        }
    ]
}