{
    "songNumber": 12,
    "title": "О, Боже чуј нè, благодарност прими",
    "verses": [
        {
            "content": {
                "lines": [
                    "О Боже, чуј нè, благодарност прими,",
                    "Ти во Христа ни дарува спасение."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Алилуја, благодарно,",
                    "Алилуја, Амин,",
                    "Алилуја, ти се слави,",
                    "Благослови нè."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "За Светиот Дух, благодарност прими,",
                    "Преку Христа со Него ни даде Ти спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Благодариме што нè спаси Ти нас,",
                    "Среќни сме ние во Тебе, Ти си наш Спас."
                ],
                "refrain": false
            }
        }
    ]
}