{
    "songNumber": 51,
    "title": "Во мила школa саботна",
    "verses": [
        {
            "content": {
                "lines": [
                    "Во мила школа саботна,",
                    "О Боже, овде, на земја,",
                    "Ме храбриш ти со Зборот свој,",
                    "Ме спремаш ти за домот твој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "(:Јас одам с радосно срце",
                    "Во школа в денот саботен.:)"
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Знам слава полн е Божји храм,",
                    "Кај учител е Господ сам,",
                    "Од Зборот Божји учам јас",
                    "Дека ме сака Исус Спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О мила школо саботна,",
                    "Отвораш врата небесна,",
                    "Низ неа гледам в слава гор'",
                    "И слушам мил ангелски хор."
                ],
                "refrain": false
            }
        }
    ]
}