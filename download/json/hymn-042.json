{
    "songNumber": 42,
    "title": "Алилуја, красно утро",
    "verses": [
        {
            "content": {
                "lines": [
                    "Алилуја, красно утро,",
                    "Покрасно од другите,",
                    "Јас во него грижи немам,",
                    "Јадој, нити неволји.",
                    "Тоа утро в сончев сјај,",
                    "Мое срце води в рај."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Свет е денот благословен,",
                    "В рајски дом ме води тој,",
                    "Благословот негов зрачи,",
                    "Свечен мир во срцето.",
                    "Полн си вечни блаженства,",
                    "Од нас бега тагата."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ти нè благослови, Спасе,",
                    "И нас како својот ден,",
                    "И со сите ти обнови",
                    "Заветот на милоста.",
                    "А штом дојде оној ден,",
                    "Земи нè во својот дом."
                ],
                "refrain": false
            }
        }
    ]
}