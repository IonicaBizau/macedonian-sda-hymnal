{
    "songNumber": 55,
    "title": "Дух твој ни дај Ти Спасе",
    "verses": [
        {
            "content": {
                "lines": [
                    "Дух твој ни дај ти, Спасе,",
                    "И остани крај нас,",
                    "И кога грев нè плаши,",
                    "Ти наш да бидеш Спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "До крајот биди со нас,",
                    "Ко Господ и наш Бог,",
                    "О дај ни верност права,",
                    "Од зло нè чувај ти."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Со благословот свети,",
                    "Оживи народ свој,",
                    "И с твојот Дух о Спасе,",
                    "Ти до нас вечно стој."
                ],
                "refrain": false
            }
        }
    ]
}