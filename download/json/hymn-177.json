{
    "songNumber": 177,
    "title": "Глеј, ангелот Господен стои",
    "verses": [
        {
            "content": {
                "lines": [
                    "Глеј, ангелот Господен стои",
                    "Покрај нас и будно чува",
                    "Кој од Бог се везден бои, ден и ноќ."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О ангеле Божји, огнени столбе,",
                    "Ти ме води в секој час.",
                    "О ангеле Божји, огнени столбе,",
                    "Води ме во вечен спас."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "И кога јад и беда прети,",
                    "С крило свое штит ни дава,",
                    "И во помош нам ни лета ден и ноќ."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Да веруваме в Божје водство,",
                    "На тој пат за домот в небо,",
                    "Нас нè води в свое царство Господ наш."
                ],
                "refrain": false
            }
        }
    ]
}