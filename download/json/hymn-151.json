{
    "songNumber": 151,
    "title": "На земја другар мил",
    "verses": [
        {
            "content": {
                "lines": [
                    "На земја другар мил,",
                    "Исус е мој,",
                    "Радост на срцето",
                    "Исус е мој.",
                    "Штом дојдат страшни дни",
                    "И појдат милите,",
                    "Мој дом и роднини,",
                    "Исус е мој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "В младоста моја, знај,",
                    "Исус е мој,",
                    "Па и во староста",
                    "Исус е мој.",
                    "Се грижи за мене,",
                    "Ме води славно Тој,",
                    "Бог е мој, вечно Тој,",
                    "Спасител мој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "И кога пројде сè,",
                    "Исус е мој,",
                    "И кога почне суд,",
                    "Исус е мој.",
                    "Со него одам јас",
                    "Во свој небесен крас.",
                    "Цар е во слава Тој,",
                    "Спасител мој."
                ],
                "refrain": false
            }
        }
    ]
}