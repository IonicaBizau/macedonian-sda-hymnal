{
    "songNumber": 147,
    "title": "О, слуги, сегде појдете",
    "verses": [
        {
            "content": {
                "lines": [
                    "О слуги, сегде појдете,",
                    "На гозба гости канете.",
                    "О готово е сега сè,",
                    "Само да дојдат гостите."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "(:Ваму ај!:)",
                    "Избегајте од грешен пат.",
                    "(:Ваму ај!:)",
                    "Денес сите Бог ве вика."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Таму од таа пустина",
                    "Чуј како ветар носи глас,",
                    "О тој е глас на Пастирот,",
                    "Тој води стадо в домот свој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Далеку в таа пустина",
                    "За помош ечи силен глас,",
                    "Вика за помош, бара спас,",
                    "И нив ги спаси, Боже наш."
                ],
                "refrain": false
            }
        }
    ]
}