{
    "songNumber": 217,
    "title": "Чуј од сегде иде глас",
    "verses": [
        {
            "content": {
                "lines": [
                    "И јас сега, и јас сега",
                    "В жетва одам,",
                    "Христов позив, Христов позив",
                    "Примам јас.",
                    "Брзам јас, о брзам јас,",
                    "В тие жолти, в тие жолти полиња,",
                    "В полињата, ај в полињата."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Чуј од сегде иде глас,",
                    "Зрел е в поле секој клас.",
                    "Повикот е небесен,",
                    "Одам и јас в овој час."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "И јас сега в жетва одам,",
                    "Христов позив примам јас,",
                    "Брзам кога Спас ме праќа",
                    "В тие жолти полиња."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Исус нас нè вика, чуј,",
                    "Жетвата е стасана.",
                    "Сега ај на работа",
                    "В тие жолти полиња."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Има многу работа,",
                    "Многу души викаат.",
                    "Веднаш ај да појдеме,",
                    "Сите ај, во овој час."
                ],
                "refrain": false
            }
        }
    ]
}