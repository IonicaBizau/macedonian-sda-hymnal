{
    "songNumber": 282,
    "title": "Надеј се, о, душо",
    "verses": [
        {
            "content": {
                "lines": [
                    "Надеј се, о душо",
                    "Во Бога ти,",
                    "Сè му ти, о кажи,",
                    "Сè во овој час.",
                    "Без страв и јад,",
                    "Бог е вечен град,",
                    "Маките ќе минат,",
                    "Болот твој и јад.",
                    "Во сека бура",
                    "Во животот,",
                    "Заклон ќе ти даде",
                    "Вечниот Бог."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Надеј се, о душо",
                    "Во Бога ти,",
                    "Својот страв му кажи,",
                    "Сè во овој час.",
                    "Штом паѓа сè",
                    "Брани те твој Бог,",
                    "Тој крај тебе стои",
                    "В сите неволји.",
                    "И Тој те чува",
                    "Од напад строг,",
                    "Чува те од гробот",
                    "Вечниот Бог."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Надеј се, о душо",
                    "Во Бога ти,",
                    "Сè му ти о кажи,",
                    "Кажи сега ти.",
                    "И в близок час",
                    "Ти ќе чуеш глас",
                    "Дека в вечна слава",
                    "Иде Исус Спас.",
                    "И после маки",
                    "Во оној час,",
                    "Радост ќе ти даде",
                    "Твој Исус Спас."
                ],
                "refrain": false
            }
        }
    ]
}