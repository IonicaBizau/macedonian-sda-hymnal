{
    "songNumber": 307,
    "title": "Драгоцен си ми Спасе",
    "verses": [
        {
            "content": {
                "lines": [
                    "Драгоцен си ми, Спасе,",
                    "за тебе копнеам,",
                    "На патот за кај тебе,",
                    "Чуј моја молитва:",
                    "(:За тебе лесно страдам,",
                    "Јас твоја љубов знам,",
                    "О дај ми таква вера,",
                    "И живот да ти дам!:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Драгоцен си ми, Спасе,",
                    "За тебе копнеам,",
                    "Со душа јас те барам",
                    "Во искушение.",
                    "(:О ти ми подај рака,",
                    "На стена стави ме,",
                    "Уцврсти мојте нозе",
                    "Да бидам верен твој!:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Драгоцен си ми, Спасе,",
                    "За тебе копнеам,",
                    "Мој пријател си верен",
                    "Во радост и во зло.",
                    "(:Ти в душата ми даваш",
                    "Спокојство, мир и спас,",
                    "И води ме со тебе",
                    "Во царство радосно!:)"
                ],
                "refrain": false
            }
        }
    ]
