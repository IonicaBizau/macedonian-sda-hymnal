{
    "songNumber": 172,
    "title": "Мој жижок е Бог",
    "verses": [
        {
            "content": {
                "lines": [
                    "Мој жижок е Бог,",
                    "Ме прави Тој јак,",
                    "Во него е пат,",
                    "Штом се спушти мрак.",
                    "Тој ме чува верно",
                    "Во злокобен час,",
                    "О Тој ми е заклон",
                    "И помош и спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "(:Мој жижок е Бог,",
                    "И Тој ми е моќ,",
                    "Ме води во слава",
                    "Чува во ноќ.:)"
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Мој жижок е Бог",
                    "И низ магли ѕид,",
                    "Тој ми дава, знам,",
                    "За вера нов вид.",
                    "Да гледам низ облак",
                    "Во Господа мој,",
                    "И видам дек' цари",
                    "Над силите Бог."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Мој жижок е Бог,",
                    "Штом дигне се бој,",
                    "Тој сила ми е",
                    "И помошник мој.",
                    "Во неволја сека",
                    "Тој ми праќа моќ,",
                    "Бог сигурно води",
                    "Низ магла и ноќ."
                ],
                "refrain": false
            }
        }
    ]
}