{
    "songNumber": 249,
    "title": "Гледај бистар поток тече",
    "verses": [
        {
            "content": {
                "lines": [
                    "Гледај бистар поток тече",
                    "Таму во далечен крај,",
                    "И кој може да го спречи",
                    "Да не прави по пат рај?"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Мили поток, јас те сакам,",
                    "Твојта убост јас ја знам,",
                    "Твојот Творец јас го славам,",
                    "За нас Тој те даде сам."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "О зар уште некој пие",
                    "Лути опој, отров клет,",
                    "Да во јад и беда дојде",
                    "Од тој опој отровен?"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Глеј во чиста вода бистра",
                    "Како птица паѓа в лет,",
                    "После пак со песна лета,",
                    "Творецот го слави свет."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Дали тече како река,",
                    "Ил' ко бистар поток тој,",
                    "Дај на земја, мили Боже,",
                    "Само вода ти ми дај."
                ],
                "refrain": false
            }
        }
    ]
}