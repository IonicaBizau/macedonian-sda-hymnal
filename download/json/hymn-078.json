{
    "songNumber": 78,
    "title": "Мој живот Ти си Христе",
    "verses": [
        {
            "content": {
                "lines": [
                    "Мој живот ти си, Христе,",
                    "За мене ти си сè,",
                    "Во срце си ми радост",
                    "И слава вечна си."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Најголем дар во тебе,",
                    "Ни даде Татко нам,",
                    "Со тебе јас сум спасен,",
                    "Со тебе храбар сум."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ги лечиш мојте рани,",
                    "И грев ми прости ти,",
                    "Со крвта своја света,",
                    "Од грев ме очисти."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Сè што ми треба овде,",
                    "Во тебе имам јас,",
                    "И теб' те, Спасе, славам,",
                    "За сека победа."
                ],
                "refrain": false
            }
        }
    ]
}