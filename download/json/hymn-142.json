{
    "songNumber": 142,
    "title": "Јас знам за еден убав свет",
    "verses": [
        {
            "content": {
                "lines": [
                    "Јас знам за еден убав свет",
                    "Кај радост полни здив,",
                    "Кај нема мрзост, зависти,",
                    "(:Кај в љубов живеј сè.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "За грижи таму не се знај,",
                    "За воздив жалосен,",
                    "О таму нема неволји,",
                    "(:Сите се радосни.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Во добро Божје живеј сè,",
                    "Во слога заедно,",
                    "За навреди не се знае,",
                    "(:За гревој нити зло.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О мило царство Божје ти,",
                    "За тебе копнеам,",
                    "О кога таму ќе сум јас,",
                    "(:Кај само радост греј.:)"
                ],
                "refrain": false
            }
        }
    ]
}