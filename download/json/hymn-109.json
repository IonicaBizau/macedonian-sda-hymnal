{
    "songNumber": 109,
    "title": "Сонце зајде, сонце зајде",
    "verses": [
        {
            "content": {
                "lines": [
                    "Сонце зајде, сонце зајде,",
                    "Тихо паѓа сегде мрак...",
                    "Сладок мир се од вис спушта,",
                    "Одмор бара слаб и јак.",
                    "Уште еден ден си мина,",
                    "Мрак е пак над земјата...",
                    "Среќни сме и таа вечер,",
                    "Близу сме до својот дом."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Поблизу, поблизу,",
                    "Поблизу во Татков дом,",
                    "Кон животот, во вечен мир,",
                    "Поблизу кон Татков дом."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Близу, близу, морнар пее,",
                    "Пее в рамна морска шир,",
                    "Што и таму гасне сонце,",
                    "И тој бара сладок мир.",
                    "Верното му срце пее,",
                    "Штом ќе мине светол ден,",
                    "Поблизу е сека вечер,",
                    "Поблизу в небесен дом."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Поблизу јас секој ден сум,",
                    "Поблизу кон домот мил,",
                    "И кај животното дрво,",
                    "Близу до тој рајски дом.",
                    "В ѕвезди небо трепка цело,",
                    "Колку мило сјае сè,",
                    "Ние сега поблизу сме,",
                    "Поблизу кон Спасот свој."
                ],
                "refrain": false
            }
        }
    ]
}