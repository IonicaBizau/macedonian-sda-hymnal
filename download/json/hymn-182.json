{
    "songNumber": 182,
    "title": "Кога Спасот ќе го видам",
    "verses": [
        {
            "content": {
                "lines": [
                    "Кога Спасот ќе го видам,",
                    "И на лице тој мил сјај,",
                    "Колку среќен јас ќе бидам,",
                    "И на гревот ќе е крај."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Скоро в пресрет јас ќе појдам,",
                    "На облак го чекам јас,",
                    "Кога дојде Тој со сила",
                    "И со слава голема."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Уште сега, глеј ми свети",
                    "Таа слава, светол зрак,",
                    "Што ли јас ќе видам тогаш",
                    "Кога мине секој мрак."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Спасе, кога в очи Твои",
                    "Погледнам во славата,",
                    "Колку среќен јас ќе бидам",
                    "Кога дојдеш, Спасе мој."
                ],
                "refrain": false
            }
        }
    ]
}