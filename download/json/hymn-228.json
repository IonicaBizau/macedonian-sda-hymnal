{
    "songNumber": 228,
    "title": "Крст свој носи, гледај в Христа",
    "verses": [
        {
            "content": {
                "lines": [
                    "Штом за Христа свет те мрази,",
                    "Со вера стој!",
                    "Ти со ништо не се жали,",
                    "Со вера стој!"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Крст свој носи, гледај в Христа,",
                    "Со вера стој!",
                    "Слушај што ти Бог твој вели,",
                    "Со вера стој!"
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "И штом гледаш дека паѓаш,",
                    "Со вера стој!",
                    "Господ с цела земја владеј,",
                    "Со вера стој!"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Штом те страв и тага плаши,",
                    "Со вера стој!",
                    "Ти од Христа сила барај,",
                    "Со вера стој!"
                ],
                "refrain": false
            }
        }
    ]
}