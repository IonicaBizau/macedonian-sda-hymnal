{
    "songNumber": 22,
    "title": "О, Душе Свети, благодарам",
    "verses": [
        {
            "content": {
                "lines": [
                    "О Душе Свети, благодарам",
                    "За безброј дарој, милости,",
                    "Кон Бога ти нè водиш нас,",
                    "Во Христа ти ни даваш спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О дај ни сила, волја дај,",
                    "Нек' подобро те слушаме,",
                    "О ти сега дај ни љубов нам,",
                    "И јакни вера, надеж дај."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Нек' подобро те славиме,",
                    "Ти светост дај ни повеќе,",
                    "Да срце наше биде храм,",
                    "Во кое ти ќе бидеш сам."
                ],
                "refrain": false
            }
        }
    ]
}