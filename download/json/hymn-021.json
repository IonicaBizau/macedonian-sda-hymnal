{
    "songNumber": 21,
    "title": "О, дојди Душе Свети",
    "verses": [
        {
            "content": {
                "lines": [
                    "О дојди, Душе Свети,",
                    "Во срцата кај нас,",
                    "И дај ни светлост твоја,",
                    "Да служиме за спас.",
                    "Со твојот оган свети",
                    "Очисти срца ти,",
                    "Да уште појќе секој",
                    "Господ го познае."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Очисти наши мисли",
                    "И води нè по пат,",
                    "Ти дај ни сила твоја,",
                    "Знам ѓаволот е лут.",
                    "Трпение ни дај ти",
                    "И верност нам ни дај,",
                    "И ова наша мудрост",
                    "Замени с' небесна."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О дојди, Душе Свети,",
                    "Приготви нè ти нас,",
                    "Со своја сила прати,",
                    "Од Божји зборој глас.",
                    "Отвори наше срце",
                    "И со нас биди сам,",
                    "На секого кој бара",
                    "Да служиме за спас."
                ],
                "refrain": false
            }
        }
    ]
}