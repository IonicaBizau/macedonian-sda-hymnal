{
    "songNumber": 125,
    "title": "Од Бога еднаш отидов",
    "verses": [
        {
            "content": {
                "lines": [
                    "Од Бога еднаш отидов,",
                    "Сега враќам се,",
                    "И горко јас се кајам, знај,",
                    "Сега враќам се."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Доаѓам, доаѓам,",
                    "Јас во домот твој,",
                    "Врата ми отвори ти,",
                    "Прими ме в свој дом."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "О многу време изгубив,",
                    "Денес враќам се,",
                    "И долго грев ме водеше,",
                    "Денес враќам се."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Во крвта своја измиј ме,",
                    "Денес враќам се,",
                    "Да бидам чист и бел ко снег,",
                    "Денес враќам се."
                ],
                "refrain": false
            }
        }
    ]
}