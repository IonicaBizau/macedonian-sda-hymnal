{
    "songNumber": 60,
    "title": "Галилеја! Галилеја!",
    "verses": [
        {
            "content": {
                "lines": [
                    "Галилеја, Галилеја,",
                    "До векот ти си сведок наш.",
                    "Сам Господ баш на морето",
                    "Зборувал му на својот род."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Галилеја, Галилеја,",
                    "Песна е таа најмила.",
                    "Ќе трае таа в светот, знај,",
                    "Сè дури постој сончев сјај."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "На езерото сакано",
                    "Прозбори Спас од чамецот...",
                    "Собраните крај обала,",
                    "Господни чуда гледаа."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Тука ги лечел болните,",
                    "Ги тешел и жалосните.",
                    "Тука Тој правел чудеса,",
                    "Него го слави земјата."
                ],
                "refrain": false
            }
        }
    ]
}