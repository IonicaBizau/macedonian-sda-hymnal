    "title": "Од грижите сум слободен",
    "verses": [
        {
            "content": {
                "lines": [
                    "Од грижите сум слободен",
                    "Во денот саботен.",
                    "Нам ни го даде тој ден Бог,",
                    "(:Со него за да сме.:)"
