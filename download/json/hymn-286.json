{
    "songNumber": 286,
    "title": "Секо утро Боже мили",
    "verses": [
        {
            "content": {
                "lines": [
                    "Секо утро Боже мили,",
                    "Твојта ме рака буди,",
                    "Зато' прими Татко благи,",
                    "Благодарност ти од мене."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Сиот свет, о мили Боже,",
                    "С твоја рака ти го храни,",
                    "И од секо зло и мака",
                    "Ти го Спасе вечно брани."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Јас ти давам срце свое,",
                    "Што ти ми го даде мене,",
                    "Нека вечно биде твое,",
                    "Полно с вера и со надеж."
                ],
                "refrain": false
            }
        }
    ]
}