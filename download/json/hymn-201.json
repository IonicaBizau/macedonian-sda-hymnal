{
    "songNumber": 201,
    "title": "Цркво Божја моли се",
    "verses": [
        {
            "content": {
                "lines": [
                    "Цркво Божја, моли се",
                    "И посвети на Бог.",
                    "Дај му срце свое ти,",
                    "Тој е многу добар.",
                    "Моли се, цркво ти,",
                    "Нека дојде смерно,",
                    "Секо' срце верно."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Кога ти со молитва",
                    "В небо дигнеш душа,",
                    "Како мирис пријатен,",
                    "Бог те тивко слуша.",
                    "Слуша Тој народ свој,",
                    "Кога тој се здружи",
                    "Верно да му служи."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Моли се на Бога ти",
                    "Благодари смерно,",
                    "Моли му се истрајно",
                    "Моли му се верно.",
                    "Благослов, навек нов,",
                    "Бог нам ни излива",
                    "Штом е вера жива."
                ],
                "refrain": false
            }
        }
    ]
}