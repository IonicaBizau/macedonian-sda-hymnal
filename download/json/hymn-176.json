{
    "songNumber": 176,
    "title": "Добро е, добро сè",
    "verses": [
        {
            "content": {
                "lines": [
                    "Добро е, добро сè,",
                    "Како водиш добро е,",
                    "За небо ме готвиш ти,",
                    "Добро е, добро сè, Господе."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Добро е, добро сè,",
                    "После овој бол и јад",
                    "Знам ме чека вечен Град,",
                    "Добро е, добро сè, Господе."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Добро е, добро сè,",
                    "В твое царство в свети крај",
                    "Ти ми готвиш вечен рај,",
                    "Добро е, добро сè, Господе."
                ],
                "refrain": false
            }
        }
    ]
