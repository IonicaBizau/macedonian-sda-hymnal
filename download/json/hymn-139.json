{
    "songNumber": 139,
    "title": "Чуј ти душо Божји глас",
    "verses": [
        {
            "content": {
                "lines": [
                    "Чуј ти, душо, Божји глас,",
                    "Фрли гревој, барај спас.",
                    "Не го служи гревот свој,",
                    "Дојди си кај Спасот твој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Дојди си, дојди си,",
                    "Ела си кај Спасот твој.",
                    "Ела си, ела си, дојди,",
                    "Дојди в домот свој."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Исус ќе ти прости сè,",
                    "Од пат грешен врати се.",
                    "Ти промени живот свој,",
                    "Против гревот стапи в бој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Кажи му на Спасот сè,",
                    "Тој те вечно сака, знај.",
                    "С Христа биди секој ден,",
                    "Појди с него в рајски стан."
                ],
                "refrain": false
            }
        }
    ]
}