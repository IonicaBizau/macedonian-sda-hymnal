{
    "songNumber": 280,
    "title": "Зошто гледаш тажно",
    "verses": [
        {
            "content": {
                "lines": [
                    "Зошто гледаш тажно",
                    "Бедно срце, ти,",
                    "Зар во љубов Божја",
                    "Нема радост, мир?",
                    "(:Гледај, срце драго,",
                    "Глеј го својот Спас,",
                    "Круна, рајска слава,",
                    "Ќе ти даде Бог.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Мачат ли те гревој,",
                    "Мачи ли те страв,",
                    "В срце мир ќе најдеш,",
                    "Глеј на Голгота.",
                    "(:О зарем не текла",
                    "Крв од Спасот твој?",
                    "Веруј, цврсто веруј,",
                    "Помош дава Тој.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Па и да те плаши",
                    "Која страшна ноќ,",
                    "Не бој се од ништо",
                    "Бог е твоја моќ.",
                    "(:О не гледај тажно",
                    "Ни во еден час,",
                    "Знај блаженство готви",
                    "Да ти даде Спас.:)"
                ],
                "refrain": false
            }
        }
    ]
}