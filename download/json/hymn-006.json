{
    "songNumber": 6,
    "title": "Сè тивко е тивко",
    "verses": [
        {
            "content": {
                "lines": [
                    "Сè тивко е тивко",
                    "Пред Бога в тој час,",
                    "О тивко е тивко",
                    "Да слушаме глас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Сè тивко е тивко",
                    "Пред Бога в тој час,",
                    "О дојдете сите,",
                    "Кај вечниот спас."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Сè тивко е тивко",
                    "Во Божјиот дом,",
                    "Кај народ се збира,",
                    "Пред милиот Бог."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Сè тивко е тивко",
                    "Пред нас стои Спас,",
                    "Тој благослов дава,",
                    "И нè сака нас."
                ],
                "refrain": false
            }
        }
    ]
}