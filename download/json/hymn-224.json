{
    "songNumber": 224,
    "title": "Дојди ти",
    "verses": [
        {
            "content": {
                "lines": [
                    "Не оправдувај се,",
                    "Појди на работа,",
                    "Твој Господ вика те,",
                    "На служба дојди ти.",
                    "О кажи, слушаш ли",
                    "Да труби Божји рог,",
                    "О дојди сега ти,",
                    "Те кани твојот Бог."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Дојди ти,",
                    "Не оправдувај се,",
                    "Дојди ти.",
                    "Те вика Господ твој,",
                    "Не оправдувај се,",
                    "Но кажи: “Еве ме!”",
                    "О сега одам јас",
                    "За теб' да работам."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Не оправдувај се",
                    "И не одлагај ти,",
                    "Ти сега јави се.",
                    "На Спасот предај се,",
                    "О предај му сè ти,",
                    "На Спасот вечен твој.",
                    "Во сешто слушај го",
                    "Тој венец ќе ти дај."
                ],
                "refrain": false
            }
        }
    ]
