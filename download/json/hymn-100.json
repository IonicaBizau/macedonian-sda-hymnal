{
    "songNumber": 100,
    "title": "Само Ти, само Ти",
    "verses": [
        {
            "content": {
                "lines": [
                    "Друго лице, освен тебе,",
                    "Спасе, не барам.",
                    "И на земја и на небо,",
                    "јас те признавам."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Само Ти, Само Ти,",
                    "Ти ќе бидеш вечно мој.",
                    "Само Ти, само Ти, ти ќе бидеш мој."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Кој друг овде, место мене,",
                    "Дал и живот свој,",
                    "Кој ме толку многу сака",
                    "Како Исус мој?"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Затоа те барам тебе",
                    "Јас на овој свет,",
                    "Дојди Спасе и ме земи,",
                    "Води в твојот дом."
                ],
                "refrain": false
            }
        }
    ]
}