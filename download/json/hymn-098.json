{
    "songNumber": 98,
    "title": "Чуј ме, о, Боже мој",
    "verses": [
        {
            "content": {
                "lines": [
                    "Чуј ме, о Боже мој,",
                    "Чуј, чуј ме ти.",
                    "Овде ме мачи грев,",
                    "Ме плаши јад.",
                    "И покрај сите зла,",
                    "Јас имам лозинка:",
                    "Вечно да бидам твој, о Боже мој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Тесен е патот прав",
                    "За вечен дом,",
                    "Но јас ќе дојдам, знам,",
                    "Кај Спасот мој.",
                    "Со Духот води ме, кај тебе поблизу,",
                    "Вечно да бидам твој, о Боже мој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Животниот ми пат,",
                    "Јас не го знам,",
                    "Ме води закон твој,",
                    "Тој ми е пат.",
                    "А кога дојдеш ти,",
                    "О радост подај ми:",
                    "Вечно да бидам твој, о Спасе мој."
                ],
                "refrain": false
            }
        }
    ]
}