{
    "songNumber": 261,
    "title": "Чуј што ти вели Бог",
    "verses": [
        {
            "content": {
                "lines": [
                    "Чуј што ти вели Бог",
                    "Да бидеш среќен ти:",
                    "Не гледај вино зло",
                    "Ни чаша опојна.",
                    "О в него смртта дреме",
                    "И гроб ти вечен спрема,",
                    "А ништо добро нема",
                    "Во тоа пиење."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Чуј што ти вели Бог:",
                    "Да презреш чаша ти,",
                    "Те води таа в гроб,",
                    "Во пропаст вечна знај."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Знај, тоа демон клет,",
                    "Те нуди с вино тој,",
                    "Да сруши в тебе сè,",
                    "Да паднеш в ропство ти.",
                    "И сека винска чаша",
                    "За нас е гробна рачка",
                    "Што не знае за јунак,",
                    "Но води го во смрт."
                ],
                "refrain": false
            }
        }
    ]
}