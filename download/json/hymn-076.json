{
    "songNumber": 76,
    "title": "Знајте ли за украс мој",
    "verses": [
        {
            "content": {
                "lines": [
                    "Знајте ли за украс мој,",
                    "Кому пеам славопој,",
                    "Кој ми е на мене сè,",
                    "Кого славам в сите дни?",
                    "- Исус ми е тоа сè."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Кој за мене беше в срам,",
                    "Мојот долг го плати сам,",
                    "Кој ми зеде гревојте,",
                    "Кој ми готви блаженство?",
                    "- Исус ми е тоа сè."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Кој ми прости в оној час,",
                    "Кој е мојот вечен Спас,",
                    "Кој ме сака секој час,",
                    "Кој ми дава мир и спас?",
                    "- Исус ми е тоа сè."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Чии Збор ме теши в сјај,",
                    "Кој ми готви вечен рај,",
                    "Кој го лечи болот мој,",
                    "И ме теши в солзи рој?",
                    "- Исус ми е тоа сè ."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Знаете ли в секој час,",
                    "Кој е мојот вечен Спас,",
                    "Радост, сè на овој свет,",
                    "А и горе в небото?",
                    "- Исус ми е тоа сè."
                ],
                "refrain": false
            }
        }
    ]
}