{
    "songNumber": 99,
    "title": "Сосем близу, сосем близу",
    "verses": [
        {
            "content": {
                "lines": [
                    "Сосем близу, сосем близу,",
                    "Сосем близу, Спасе мој,",
                    "С цело срце јас те сакам,",
                    "Појќе и од живот свој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Овде сум, овде сум,",
                    "Сосем близу, Спасе мој,",
                    "Секој грев ми зеде ти,",
                    "В срце надеж даде ми."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "И од маки ти ме спаси",
                    "И од тешко страшно зло,",
                    "Своја милост ти му даваш",
                    "На тој кој ти срце дај."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Само тебе јас те сакам,",
                    "Се надевам во тебе,",
                    "Спаси ме од зло и гревој,",
                    "В твојот дом ме води ти."
                ],
                "refrain": false
            }
        }
    ]
}