{
    "songNumber": 112,
    "title": "Јас срцето го давам",
    "verses": [
        {
            "content": {
                "lines": [
                    "Јас срцето",
                    "Го давам сега сам,",
                    "О Боже, Творче мој.",
                    "О земи го,",
                    "Јас смирен стојам глеј,",
                    "Пред твојот престол свет.",
                    "Од срце појќе што да дадам,",
                    "Во твојта милост да се врати?",
                    "Ти спаси го, ти спаси го."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ти спаси го,",
                    "О ти си милостив,",
                    "И знам да примаш сè.",
                    "О прими го,",
                    "На својте гради ти,",
                    "Се кајам горко јас.",
                    "За опроштај те моли сега,",
                    "Се надева во милост тоа,",
                    "И секогаш од грев се кај."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ти спаси го,",
                    "О Татко смилуј се,",
                    "О прости му ти сè.",
                    "Свој мир му дај,",
                    "О добри Оче мој,",
                    "Да најде надеж пак.",
                    "Да остане кај тебе сега,",
                    "Од гревој да далеку бега",
                    "Во заклон твој, во заклон твој."
                ],
                "refrain": false
            }
        }
    ]
}