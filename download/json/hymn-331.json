{
    "songNumber": 331,
    "title": "Тој вечен живот дава",
    "verses": [
        {
            "content": {
                "lines": [
                    "О тежок животот е,",
                    "Преполнет е со грев,",
                    "И лага и лакомство,",
                    "Успех е тоа цел."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ти ако бараш среќа,",
                    "Та близу е до нас,",
                    "Тоа е живот вечен,",
                    "Од Христа подарен."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Во срцето со Бога",
                    "Ние сме негови,",
                    "Штом со нас Тој е сега",
                    "Друго не сакаме."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Тој вечен живот дава",
                    "На своите верници,",
                    "Цел живот да ни мине",
                    "С љубов и молитви."
                ],
                "refrain": false
            }
        }
    ]
}