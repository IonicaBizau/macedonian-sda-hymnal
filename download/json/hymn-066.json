{
    "songNumber": 66,
    "title": "Твоја победа е Спасе",
    "verses": [
        {
            "content": {
                "lines": [
                    "Твоја победа е, Спасе,",
                    "Имаш славен ореол.",
                    "После лута, тешка борба,",
                    "Од грев ме ослободи."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Јас те славам, Спасе верен,",
                    "Што ти умре за мене,",
                    "И со крвта твоја света",
                    "Нам ни даде вечен спас."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Јас во ова земно тело",
                    "Како в сон те гледам сè.",
                    "Величество твое гледам,",
                    "В вечна слава небесна."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Пејте верни, пејте сега,",
                    "Сегде да се чуе глас.",
                    "Дајте му, о красни палми,",
                    "Зашто умре Тој за нас."
                ],
                "refrain": false
            }
        }
    ]
}