{
    "songNumber": 73,
    "title": "Во Христа сум спасен јас",
    "verses": [
        {
            "content": {
                "lines": [
                    "Во Христа сум спасен јас,",
                    "О среќа е,",
                    "Во крвта ме изми Тој,",
                    "Ме прими Спас.",
                    "Од грев и од грешно сè",
                    "Сум очистен,",
                    "И пеам јас радосен,",
                    "Во овој час."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Славете ја љубовта,",
                    "Силната нејна моќ,",
                    "Вечно ја славете,",
                    "Нè спаси нас."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Во Христа сум спасен јас,",
                    "Ме спаси Тој,",
                    "Тој лечи од слабости",
                    "И цврсне ме.",
                    "Од маки ме спаси Тој,",
                    "Ме спаси Тој,",
                    "Ми ги брише солзите,",
                    "Спасител мој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О Исусе распнати,",
                    "Те славам јас,",
