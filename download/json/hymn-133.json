{
    "songNumber": 133,
    "title": "Ноќна темнина се спрема",
    "verses": [
        {
            "content": {
                "lines": [
                    "Ноќна темнина се спрема",
                    "Да направи на сè крај,",
                    "Скоро, скоро живот мине",
                    "И со него сончев сјај."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Дал' си готов ти,",
                    "Дал' си готов ти?",
                    "Божји Дух те вика",
                    "В овој час.",
                    "Дал' си готов ти, дал' си готов ти?",
                    "Ела, не чекај, и прими спас."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Ако гревот не победиш",
                    "С Бога не се смириш ти,",
                    "Вечна смрт ти денес прети,",
                    "Исус сега вика те."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Милост, љубов и спасење",
                    "Исус дава в секој час,",
                    "Дојди дури денот трае,",
                    "Дај му срце, прими спас."
                ],
                "refrain": false
            }
        }
    ]
