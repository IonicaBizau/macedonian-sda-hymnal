{
    "songNumber": 234,
    "title": "Таму в туѓа земја глеј",
    "verses": [
        {
            "content": {
                "lines": [
                    "Таму в туѓа земја глеј,",
                    "Во Вавилон зли,",
                    "Даниел се бори сам,",
                    "На Бога верен тој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ко Даниел служи",
                    "На Бог секој ден,",
                    "Ти од маки не се бој,",
                    "Биди сведок прав."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Бори се, о храбро ти,",
                    "Бог е заклон твој,",
                    "И в надеж ко Даниел,",
                    "Од ништо не се бој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ко Даниел верен ти,",
                    "Држи закон в страв,",
                    "Немој да се умориш,",
                    "Ти биди јак и прав."
                ],
                "refrain": false
            }
        }
    ]
}