{
    "songNumber": 308,
    "title": "Штом си тажен, штом си разочаран",
    "verses": [
        {
            "content": {
                "lines": [
                    "Штом си тажен, штом си разочаран,",
                    "Кажи на Спасот, кажи на Спасот.",
                    "Штом си скршен, штом си обесхрабрен,",
                    "Кажи му на Спасот твој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Кажи на Спасот, кажи на Спасот,",
                    "Најдобар другар е твој.",
                    "Како него верен другар немаш,",
                    "Кажи му го јадот свој."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Кога течат покајнички солзи,",
                    "Кажи на Спасот, кажи на Спасот.",
                    "Кога патиш за гревојте тајни,",
                    "Кажи му на Спасот свој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Плаши ли те темен облак грижи,",
                    "Кажи на Спасот, кажи на Спасот.",
                    "За иднина кога ти се боиш,",
                    "Кажи му на Спасот свој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Кога дојдат смртни мисли мрачни,",
                    "Кажи на Спасот, кажи на Спасот.",
                    "Кога мислиш на небесно царство",
                    "Кажи му на Спасот свој."
                ],
                "refrain": false
            }
        }
    ]
}