{
    "songNumber": 26,
    "title": "Крај живата сме река ние",
    "verses": [
        {
            "content": {
                "lines": [
                    "Крај живата сме река ние,",
                    "Што гасне сека жед,",
                    "И Исус Господ нас нè вика",
                    "на тие обали."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "И сега сме крај таа река,",
                    "(: Еве нè крај таа река :)",
                    "Изворот на животот."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "На уморните Исус служи,",
                    "Им дава одмор свој,",
                    "И нежно лечи лути рани,",
                    "Да биде секој здрав."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О, дојди овде, дојди сега,",
                    "На Христа рака дај,",
                    "Блаженство сега Тој ти дава,",
                    "Те води Тој во рај."
                ],
                "refrain": false
            }
        }
    ]
