{
    "songNumber": 230,
    "title": "Веруј само секој ден",
    "verses": [
        {
            "content": {
                "lines": [
                    "Веруј само секој ден,",
                    "Веруј, вели Исус сам.",
                    "И во деној тешки, зли,",
                    "Исус вели: “Веруј ти!”"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Верувам до крајот сè,",
                    "Сè што велиш, Господи.",
                    "Јас го слушам твојот глас:",
                    "“Веруј, веруј, в секој час!”"
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Јасно свети Духот твој,",
                    "Во животот тажен мој.",
                    "Помош ти ми испрати",
                    "Кога рече: “Веруј ти!”"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Сега одам весело",
                    "В домот горе на небо.",
                    "Исус дава сила, моќ,",
                    "Со зборојте: “Веруј ти!”"
                ],
                "refrain": false
            }
        }
    ]
}