{
    "songNumber": 263,
    "title": "Мали капки вода",
    "verses": [
        {
            "content": {
                "lines": [
                    "Мали капки вода,",
                    "Ситен песок, знај,",
                    "Чинат силно море",
                    "И тој земјин рај.",
                    "Деновите наши",
                    "Кога минат в ред,",
                    "Чинат минатото",
                    "Па и вечноста."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Мали раце можат",
                    "Да те послужат,",
                    "И на Бога тие",
                    "Верни да му се.",
                    "Верни очи будно",
                    "Бдеат ден и ноќ,",
                    "Љубов многу чини,",
                    "Силна и е моќ."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Кој и малку греши,",
                    "Паѓа веќе роб,",
                    "Гревот бргу расте,",
                    "Води тој во гроб.",
                    "Мало доброчинство,",
                    "Љубов наша знај,",
                    "Може и од смртта",
                    "Да нè води в рај."
                ],
                "refrain": false
            }
        }
    ]
}