{
    "songNumber": 90,
    "title": "Исус Христос пак ќе дојде",
    "verses": [
        {
            "content": {
                "lines": [
                    "Исус Христос пак ќе дојде,",
                    "Само сега в слава, моќ,",
                    "С безброј ангели ќе дојде",
                    "И со сила голема.",
                    "(:Алилуја, в свое царство иде Тој!:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ќе го види секо око,",
                    "Ќе му пеат верните,",
                    "А со страв ќе нижат поглед",
                    "Тие што го распнале.",
                    "(:Да им суди иде Тој во царството!:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Достоинство, чест и слава",
                    "Само теб' ти припаѓа.",
                    "В царството го свое прими",
                    "Сиот верен народ свој.",
                    "(:Спасе, дојди, царуј ти во царството!:)"
                ],
                "refrain": false
            }
        }
    ]
}