{
    "songNumber": 313,
    "title": "Моли се без почивка",
    "verses": [
        {
            "content": {
                "lines": [
                    "Господ твој те вика,",
                    "Чуј ти негов глас,",
                    "И со својте зборој",
                    "Тој ти дава власт.",
                    "Во делото свето",
                    "Биди верен ти,",
                    "Да на крајот примиш",
                    "Венец славен ти."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Моли се без почивка,",
                    "Моли се и с љубов верно прави сè,",
                    "А штом дојде Господ твој,",
                    "Тогаш ти ќе примиш славна награда."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Оди ти кај брат ти",
                    "Уморен од зло,",
                    "Гревот тешко ропство",
                    "Го измачува.",
                    "Истргни го брат ти",
                    "Од страшниот мрак,",
                    "Веста му ја јави,",
                    "Да го сака Бог."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "На тие без надеж",
                    "Што се ближи крај,",
                    "И на сите жедни",
                    "Евангелие дај.",
                    "Со љубов им кажи",
                    "Да е Господ благ,",
                    "И на сите дава",
                    "Вечен живот драг."
                ],
                "refrain": false
            }
        }
    ]
}