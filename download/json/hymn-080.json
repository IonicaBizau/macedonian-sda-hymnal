{
    "songNumber": 80,
    "title": "Од Христа река тече",
    "verses": [
        {
            "content": {
                "lines": [
                    "Од Христа река тече,",
                    "Бистра ко кристал чист,",
                    "Река на живот вечен,",
                    "Ни дава живот нам.",
                    "(:Покрај неа, за нас сега",
                    "Цвета вечен рај.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О каква радост чека",
                    "В бистриот нејзин сјај,",
                    "Кај златни харфи ѕвонат",
                    "И свети златен Град.",
                    "(:Красна река, полна лекој",
                    "Чека верни свој.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О реко водо жива,",
                    "Ти прими поздрав мој,",
                    "Во тебе жед јас гасам",
                    "О реко Спасе мој.",
                    "(:Секој ден,",
                    "И уште рано,",
                    "Пијам од тебе.:)"
                ],
                "refrain": false
            }
        }
    ]
}