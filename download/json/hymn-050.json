{
    "songNumber": 50,
    "title": "Мили Боже, Ти погледај",
    "verses": [
        {
            "content": {
                "lines": [
                    "Мили Боже, ти погледај",
                    "Сега на нас од небо,",
                    "(:Благодарност, Оче, прими,",
                    "Прими ти од народ твој.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Твои деца ќе бидеме,",
                    "Дај ни права верност ти,",
                    "(:Да ти служиме на земја,",
                    "Па и таму в вечноста.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ќе бидеме верно стадо,",
                    "Послушни и стрпливи,",
                    "(:Дека и ти за нас беше",
                    "Трпелив и милостив.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О пастиру, води, паси,",
                    "Јагниња и овци нас,",
                    "(:И доведи нè во слава",
                    "Да те славиме за спас.:)"
                ],
                "refrain": false
            }
        }
    ]
}