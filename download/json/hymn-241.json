{
    "songNumber": 241,
    "title": "Кои се моите браќа",
    "verses": [
        {
            "content": {
                "lines": [
                    "Кои се мојте браќа,",
                    "Кои сестри се?",
                    "Сите деца Божји,",
                    "Кои верни се."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Тоа мало стадо",
                    "Што свој Пастир знај,",
                    "Чуј го тоа вели:",
                    "Тој е вечен Спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Тие кои прават",
                    "Сè за Спасот свој,",
                    "За нив живот в слава",
                    "Готви вечен Бог."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Тие ми се браќа",
                    "А и сестри се,",
                    "Сите Божји деца,",
                    "Свети нека се."
                ],
                "refrain": false
            }
        }
    ]
}