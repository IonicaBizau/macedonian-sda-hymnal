{
    "songNumber": 232,
    "title": "Кој го нашол мирот Христов",
    "verses": [
        {
            "content": {
                "lines": [
                    "Кој го нашол мирот Христов",
                    "Тој е среќен секогаш,",
                    "Божјата го љубов чува,",
                    "Не ја губи надежта."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Кај да појде в земен живот,",
                    "С Исус тој е на прав пат,",
                    "И го слави Спасот сегде,",
                    "Христос му е радоста."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Кој во Христа надеж има,",
                    "Мирен е во Спасот свој,",
                    "И без гревој тој се готви",
                    "За небесен славен дом."
                ],
                "refrain": false
            }
        }
    ]
}