{
    "songNumber": 256,
    "title": "О дајте чест",
    "verses": [
        {
            "content": {
                "lines": [
                    "О дајте чест,",
                    "На Бога пејте сега,",
                    "Со радост слуша",
                    "Од срце песни свети,",
                    "О пејте му на Спасот свој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "До небо пеј,",
                    "Нек’ ори само слава,",
                    "Го слуша тој глас",
                    "Од срца мали наш Бог,",
                    "И среќен е, и среќен е."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Наш глас е слаб,",
                    "Но Исус наш е близу,",
                    "Со нас е сега",
                    "Во домот негов свети,",
                    "Нè слуша Тој, нè слуша Тој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О иде ден,",
                    "И скоро зора зори,",
                    "Да верен народ",
                    "На небо Бога слави",
                    "Во вечноста, во вечноста."
                ],
                "refrain": false
            }
        }
    ]
}