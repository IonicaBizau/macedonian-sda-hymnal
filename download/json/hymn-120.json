{
    "songNumber": 120,
    "title": "О, Спасе еве ме",
    "verses": [
        {
            "content": {
                "lines": [
                    "О Спасе, еве ме,",
                    "Јас стојам пред тебе,",
                    "Во крвта твоја барам спас,",
                    "Што за мен' проли ти."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Пред тебе стојам јас,",
                    "За милост молам те,",
                    "Измиј ме мене в крвта ти,",
                    "Под крстот голготски."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Јас сум полн слабости,",
                    "Ти биди мое сè,",
                    "Во крвта твоја чисти ме,",
                    "О чисти ме од сè."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О Спасе, добро знам,",
                    "За мене даде сè,",
                    "И крвта си ја проли ти,",
                    "На крстот за мене."
                ],
                "refrain": false
            }
        }
    ]
}