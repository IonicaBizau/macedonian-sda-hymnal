{
    "songNumber": 321,
    "title": "На Бога, чест, слава и фала",
    "verses": [
        {
            "content": {
                "lines": [
                    "На Бога чест, слава и фала",
                    "Му пеат милиони.",
                    "На Бога чест небеса пеат,",
                    "Му пеат милиони.",
                    "Спасени одат во слава",
                    "Горе во приготвен дом,",
                    "Облак ги носи на небо",
                    "Горе во златниот Град."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "На Бога чест, слава и фала",
                    "Радосно сите пејте.",
                    "Исус нè води во слава,",
                    "Таму во приготвен Град."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "На Бога чест, слава и фала",
                    "Му пеат милиони.",
                    "Исус е овде со нас сега,",
                    "Му пеат милиони.",
                    "В борбата верни на Бога,",
                    "Со Христа се спасени.",
                    "Одмор ги чека во слава,",
                    "За нив е приготвен Град."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "На Бога чест, слава и фала,",
                    "Борбата свршена е.",
                    "Победата ја слават сите,",
                    "Крај е на страшниот грев.",
                    "Радосни лица им светат,",
                    "Победа зрачи од нив.",
                    "Мали и големи с Христа,",
                    "Со вера гледајте ги."
                ],
                "refrain": false
            }
        }
    ]
}