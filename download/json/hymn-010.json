{
    "songNumber": 10,
    "title": "Бог е со нас овде",
    "verses": [
        {
            "content": {
                "lines": [
                    "Бог е со нас овде,",
                    "Нека сите верни",
                    "Својте глави ги наведнат.",
                    "Бог е со нас овде,",
                    "Сите в стравот негов",
                    "Пејте му, о пејте славно.",
                    "Пејте му славопој,",
                    "Тој е наша слава,",
                    "Тој е Господ Бог наш."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Бог е со нас овде,",
                    "Кого херувими",
                    "В непрестан го слават сега.",
                    "С покриено лице,",
                    "Пеат серафими,",
                    "Праведно Тој владеј вечно.",
                    "Боже наш, чуј нè нас,",
                    "Благодарност прими,",
                    "Прими чест и слава."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ја фрливме, Боже,",
                    "Сета светска слава,",
                    "Сите земни празни сласти.",
                    "Нека жртва наша:",
                    "Душа, дух и тело",
                    "Тебе, Оче, ти е драга.",
                    "Само ти, за нас си,",
                    "Овде радост права,",
                    "Прими чест и слава."
                ],
                "refrain": false
            }
        }
    ]
}