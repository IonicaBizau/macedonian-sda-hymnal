{
    "songNumber": 304,
    "title": "О, граде ти, кај живеј Бог",
    "verses": [
        {
            "content": {
                "lines": [
                    "Во копнеж гледам тој,",
                    "Со вера гледам јас,",
                    "Низ ѕвезден гледам рој,",
                    "Во Ерусалим град.",
                    "Во Спасот гледам мој,",
                    "И негов мили двор,",
                    "Во вечен гледам дом,",
                    "Кај сите пеат в хор."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О Граде ти, кај живеј Бог,",
                    "Копнеж ми е на срцето",
                    "Да прејдам праг и видам те,",
                    "И сè што Бог ни спрема нам."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Во копнеж тој со вера гледам јас",
                    "Низ ѕвезди рој, во Ерусалим град,",
                    "Во Спасот мој и негов убав двор,",
                    "Во вечен дом кај сите пеат в хор."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Химната чуј, тој силен глас,",
                    "И харфин звук околу нас,",
                    "Тој славопој од спасени,",
                    "Јагнето Божје ги води."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Да одам јас, кај појде Он,",
                    "И седнам баш до негов трон,",
                    "Јас се надевам, копнеам,",
                    "И затоа го следам јас."
                ],
                "refrain": false
            }
        }
    ]
}