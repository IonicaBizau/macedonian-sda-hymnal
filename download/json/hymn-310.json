{
    "songNumber": 310,
    "title": "Чуј, Боже гласот наш",
    "verses": [
        {
            "content": {
                "lines": [
                    "Чуј, Боже, гласот наш,",
                    "Те вика народ твој,",
                    "Те моли, Боже, тој",
                    "Одбрани го.",
                    "Ко слаб, го знаеш ти,",
                    "Со тебе јак е тој,",
                    "Отстрани секо зло",
                    "Биди му Спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Чуј, Боже, гласот наш,",
                    "Јави се ти.",
                    "Со лице расветли",
                    "Во ноќта пат."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Над гревот моќ ми дај",
                    "И води народ свој,",
                    "Со твојот силен Збор,",
                    "Во победа.",
                    "Нек твојот Збор се сјај",
                    "Во нас на земјата,",
                    "На сите кажи ја",
                    "Вистината."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Со успех крунисај",
                    "Трудот во делото,",
                    "Да биде слава на името ти.",
                    "Честа ти припаѓа,",
                    "Возвишен биди ти",
                    "Сред народ верен свој",
                    "На светот тој."
                ],
                "refrain": false
            }
        }
    ]
}