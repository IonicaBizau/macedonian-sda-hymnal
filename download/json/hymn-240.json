{
    "songNumber": 240,
    "title": "Глеј , Бог е љубов",
    "verses": [
        {
            "content": {
                "lines": [
                    "Глеј, Бог е љубов,",
                    "Од зло ме спаси,",
                    "Глеј, Бог е љубов,",
                    "Ме сака Тој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Јас знам од Спасот мој,",
                    "Бог да е љубов,",
                    "Мој Бог е љубов,",
                    "Ме сака Тој."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Во оков тежок",
                    "Јас знам бев фрлен,",
                    "Во оков тежок",
                    "За вечна смрт."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Бог прати Христос,",
                    "Откупителот,",
                    "Бог прати Христос",
                    "За спасот мој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "И Тој ме викна,",
                    "Во милост своја,",
                    "И Тој ме викна",
                    "Со Духот свој."
                ],
                "refrain": false
            }
        }
    ]
}