{
    "songNumber": 19,
    "title": "Славете, небеса Бога",
    "verses": [
        {
            "content": {
                "lines": [
                    "Славете, небеса, Бога,",
                    "Славете го ангели!",
                    "И ти, сонце, Бога слави,",
                    "И ти, земјо слави го.",
                    "Славете го оти рече,",
                    "И се стори така сè.",
                    "Својот Збор Тој не го мени,",
                    "Нити својте закони."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Божја мудрост, вечна сила,",
                    "Слави сè од секогаш.",
                    "Зборуват безбројни дела,",
                    "Дека Бог ги создаде.",
                    "Дали може да се молчи,",
                    "Кога Бога слави сè?",
                    "Сега секој нека пее",
                    "И го слави Творецот."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Сиот свет од земја створен,",
                    "Тебе те прославува.",
                    "Дај ни сега нова сила,",
                    "Силата на Духот твој.",
                    "Кога на Стаклено море,",
                    "Стигне оној среќен час,",
                    "Во тој спасен, голем народ,",
                    "Да те славам вечно јас."
                ],
                "refrain": false
            }
        }
    ]
}