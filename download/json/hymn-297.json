{
    "songNumber": 297,
    "title": "Во Бога мирно заспал тој",
    "verses": [
        {
            "content": {
                "lines": [
                    "Во Бога мирно заспал тој,",
                    "Тој мир е дело на милост.",
                    "Блажен и мирен покој е,",
                    "Го прати него надежта."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Во Бога мирно заспал тој,",
                    "Само за час се раздели.",
                    "Ќе чека воскресение,",
                    "Во вечен живот ќе стане."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Во Бога мирно заспал тој,",
                    "Спремен за вечен живот свој.",
                    "И сите ќе нè земе Спас,",
                    "Бог сам ќе нè пробуди нас."
                ],
                "refrain": false
            }
        }
    ]
}