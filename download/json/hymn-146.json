{
    "songNumber": 146,
    "title": "Канете го нека дојде",
    "verses": [
        {
            "content": {
                "lines": [
                    "Канете Го нека дојде",
                    "Секој којшто бара спас,",
                    "Само овој пат е вечен,",
                    "Добар лек за секој јад.",
                    "Ваму нека дојде секој,",
                    "Којшто пати в гревој зли,",
                    "Исус сака да ги спаси,",
                    "Тој ги чека да дојдат."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Викајте и мали деца",
                    "Да го видат Исуса,",
                    "Сега за нив баш е време,",
                    "Нек во вечен појдат дом.",
                    "По прав пат ги води Спасот,",
                    "Чува ги од секо зло,",
                    "Сите сега нека дојдат",
                    "Да ги спаси Господ Бог."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Нека дојдат сите сега,",
                    "Кои в гревој трпат срам,",
                    "Кажете им за Исуса,",
                    "Дека ќе ги прими Тој.",
                    "Ден по ден си мине време,",
                    "Бргу иде ноќен мрак,",
                    "Нека сите бргу дојдат,",
                    "Ете, гасне заден зрак."
                ],
                "refrain": false
            }
        }
    ]
}