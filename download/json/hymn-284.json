{
    "songNumber": 284,
    "title": "Сега немој да ме минеш",
    "verses": [
        {
            "content": {
                "lines": [
                    "Сега немој да ме минеш,",
                    "Спасе, чуј ми глас,",
                    "Немој а да не ми простиш,",
                    "Дај ми мир и Спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Спасе, Спасе, чуј го мојот глас,",
                    "Ти опрости ми гревојте,",
                    "Дај ми живот нов."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Милостив за мене биди,",
                    "Дај ми заклон свој,",
                    "Признавам ги мојте гревој,",
                    "Дај да бидам твој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Ти си утеха и надеж,",
                    "Ти си ми, о сè,",
                    "Сјаен бисер в мојот живот,",
                    "Мили Исусе."
                ],
                "refrain": false
            }
        }
    ]
}