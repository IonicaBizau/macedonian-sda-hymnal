{
    "songNumber": 145,
    "title": "О, гледај го на крстот Спасот свој",
    "verses": [
        {
            "content": {
                "lines": [
                    "О гледај го на крстот Спасот свој,",
                    "Одамна Тој те вика, знај.",
                    "Под крстот слава ќе добиеш,",
                    "О слава, но не како земната."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Гледај го ти Спасот свој,",
                    "На Голгота гледај го.",
                    "Гледај го, те вика Тој,",
                    "Вечен живот да ти дај."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "О пази ти овде на тој свет Збор,",
                    "И ветување Божие.",
                    "Те варди од искушение,",
                    "Ги слуша Тој твоите молитви."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О гледај го на крстот Спасот свој,",
                    "За тебе таму распнат е.",
                    "Во тага Тој ти е утеха,",
                    "О гледај во него до крајот сè."
                ],
                "refrain": false
            }
        }
    ]
}