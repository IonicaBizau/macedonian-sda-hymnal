{
    "songNumber": 333,
    "title": "Сејачи сејте!",
    "verses": [
        {
            "content": {
                "lines": [
                    "Сејачи сејте и доброто посејте",
                    "В младата нива во нас,",
                    "Вистини здрави во душите внесете,",
                    "Важен е денешен час.",
                    "Сејачи сејте и доброто посејте",
                    "В младата нива во нас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Сејте и копнеж за правда божествена,",
                    "Љубов посејте не зло,",
                    "Милост во срцата и братска доверба,",
                    "Нека го прати тој труд.",
                    "Сејачи сејте и доброто посејте",
                    "В младата нива во нас."
                ],
                "refrain": false
            }
        }
    ]
}