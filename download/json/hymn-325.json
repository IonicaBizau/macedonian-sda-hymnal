{
    "songNumber": 325,
    "title": "Доаѓа пак, доаѓа пак",
    "verses": [
        {
            "content": {
                "lines": [
                    "Гласници, с' труба огласете знак:",
                    "Исус ни доаѓа пак.",
                    "Патници, носете светлост низ мрак:",
                    "Наш Исус доаѓа пак."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Доаѓа пак, доаѓа пак,",
                    "Исус ни доаѓа пак.",
                    "Нека се чуе на сегде тој глас:",
                    "Исус ни доаѓа пак.",
                    "Бескрајна војска е со него глеј,",
                    "И славна песна се леј."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Бранови морски, разнесете глас:",
                    "Исус ни доаѓа пак.",
                    "В далечни земји нек' се чуе глас:",
                    "Наш Исус иде по нас."
                ],
                "refrain": false
            }
        }
    ]
}