{
    "songNumber": 265,
    "title": "Свое детско стадо",
    "verses": [
        {
            "content": {
                "lines": [
                    "Свое детско стадо",
                    "Будно гледа Спас,",
                    "И Тој навек слуша",
                    "Ѕвонлив детски глас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "С' рака дете води,",
                    "Сегде чува Тој,",
                    "А и помош дава",
                    "На цел народ свој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Господ нас нè храни,",
                    "Бдее Тој над нас,",
                    "И од зло нè брани",
                    "Навек Исус Спас."
                ],
                "refrain": false
            }
        }
    ]
}