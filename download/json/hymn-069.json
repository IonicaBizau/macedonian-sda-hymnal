{
    "songNumber": 69,
    "title": "Наш славен лекар Исус е",
    "verses": [
        {
            "content": {
                "lines": [
                    "Наш славен лекар Исус е,",
                    "И со нас Тој е сега,",
                    "Нам утеха ни дава, знај,",
                    "И Тој е наша надеж."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Најсладок е оној глас,",
                    "С кој се слави Исус Спас,",
                    "Најарна е песна, знам,",
                    "Исус, само Исус."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "И крстот наш го зеде Спас,",
                    "На себе Тој го стави,",
                    "Во слава Тој нè води нас,",
                    "Од смртта Тој нè спаси."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "За мене умре, Спасе, ти,",
                    "Да ти е слава, Христе,",
                    "И сешто ти ми прости, знам,",
                    "О Спасе, мили Спасе."
                ],
                "refrain": false
            }
        }
    ]
}