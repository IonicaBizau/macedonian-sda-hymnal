{
    "songNumber": 188,
    "title": "Кој сака со нас на Сион",
    "verses": [
        {
            "content": {
                "lines": [
                    "(:Кој сака со нас на Сион,:)",
                    "Нè води Исус нас.",
                    "(:Таму нè чека убав дом:)",
                    "И вечен мир и спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Сионе мили,",
                    "Бргу да те видиме.",
                    "Затоа брзаме радосни,",
                    "Да дојдеме побргу."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "(:О таму сакам да сум јас:)",
                    "Во спасениот збор,",
                    "(:За кои вели Божји Збор:)",
                    "Да им е зготвен дом."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "(:О ете иде Господ наш:)",
                    "Со својта славна моќ,",
                    "(:Кај себе да нè води нас:)",
                    "Во среќа блажена."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "(:И сите маки, сиот јад:)",
                    "Тогаш ќе престанат,",
                    "(:И со палми во рацете:)",
                    "Верните ќе пеат."
                ],
                "refrain": false
            }
        }
    ]
}