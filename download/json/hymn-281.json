{
    "songNumber": 281,
    "title": "Знам сè ќе мине",
    "verses": [
        {
            "content": {
                "lines": [
                    "Знам сè ќе мине,",
                    "Жалост и јад,",
                    "Маките, борбите,",
                    "Умор и глад.",
                    "И после маки",
                    "На овој свет,",
                    "Радост ќе дојде пак",
                    "И рајски цвет."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Радост ќе дојде",
                    "Штом ноќта пројде,",
                    "И после борбите",
                    "Те чека мир."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Низ солзи сееш",
                    "На земјата,",
                    "Радост ќе жнееш ти",
                    "Во славата.",
                    "На сите маки",
                    "Ќе дојде крај,",
                    "Бог ќе ти даде мир",
                    "И вечен рај."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Скоро ќе дојде",
                    "Господ и Спас,",
                    "Да води народ свој",
                    "Во вечен дом.",
                    "Затоа пеам",
                    "Јас свети пој,",
                    "Нему му давам сè",
                    "За венец свој."
                ],
                "refrain": false
            }
        }
    ]
}