{
    "songNumber": 24,
    "title": "Збор ме води Твој",
    "verses": [
        {
            "content": {
                "lines": [
                    "Дојдете и слушајте,",
                    "Зборој Божји, Божји глас,",
                    "Извор е на вистина,",
                    "В живот Тој нè води нас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Збор ме води твој,",
                    "Патот прав е тој,",
                    "Преку вечна милост води в рај,",
                    "Радост моја овде си,",
                    "(:Сигурно ме водиш ти.:)"
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Мудрост па и знаење,",
                    "Што е за спасение,",
                    "Учител и Творец знам,",
                    "Пастир наш е Исус сам."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Твојот Збор е мил и јак,",
                    "Јасно свети тој во мрак,",
                    "Кој го држи твојот Збор,",
                    "Знам ќе дојде в твојот двор."
                ],
                "refrain": false
            }
        }
    ]
}