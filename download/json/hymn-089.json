{
    "songNumber": 89,
    "title": "Со Збор Божји труби гласно",
    "verses": [
        {
            "content": {
                "lines": [
                    "Ој стражару, труби гласно,",
                    "Јави ти со силен глас,",
                    "Време е да дојде Спасот,",
                    "Господ наш во овој час."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Со Збор Божји труби гласно,",
                    "Нека знае овој свет,",
                    "Ти им јави сегде јасно",
                    "Дека спас им нуди Бог."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "И над гори и над води,",
                    "Нека труби јасен глас,",
                    "Сегде јасно да се чуе:",
                    "Скоро наш ќе дојде Спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Уморните нека дојдат,",
                    "В одмор благ кај Спасот свој,",
                    "Скоро Исус ќе ни дојде,",
                    "В сета слава небесна."
                ],
                "refrain": false
            }
        }
    ]
}