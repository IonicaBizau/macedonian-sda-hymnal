{
    "songNumber": 203,
    "title": "Своја светлост, Боже",
    "verses": [
        {
            "content": {
                "lines": [
                    "Своја светлост, Боже,",
                    "Дај ми в срце ти,",
                    "Спремност и за жртва",
                    "На олтарот твој.",
                    "Појќе твоја вера",
                    "Дај ми, Спасе мој,",
                    "Да ти служам верно",
                    "Како слуга твој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Да те појќе славам,",
                    "Ревност ти ми дај,",
                    "Дај ми верност твоја,",
                    "И од Духот сјај.",
                    "Да помогнам сакам",
                    "На ближниот свој,",
                    "Верно да ти служам",
                    "Како слуга твој."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Дај ми совест будна",
                    "И од твој Дух моќ,",
                    "За Теб' да се трудам,",
                    "Дур' не дојде ноќ.",
                    "Вера ми ти снажи,",
                    "О ти, Спасе мој,",
                    "Да до крајот бидам",
                    "Верен сведок твој."
                ],
                "refrain": false
            }
        }
    ]
}