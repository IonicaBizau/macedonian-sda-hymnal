{
    "songNumber": 335,
    "title": "О, чудно е Божјето слово",
    "verses": [
        {
            "content": {
                "lines": [
                    "О чудно е Божјето слово,",
                    "Со чудење го читаме,",
                    "За чудното дело од Христа,",
                    "За планот откупителен."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "О верувај в таа вест чудна,",
                    "Си откупен и оправдан,",
                    "О веруј в љубовта бескрајна,",
                    "И покорен, о биди ти."
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "О дојдете кај Спасителот",
                    "Што жалите и патите,",
                    "Радосна вест Тој нам ни носи",
                    "И нежно Тој да теши знај."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Скривалиште поарно нема",
                    "О нигде по целиот свет,",
                    "Не гледајте земната слава,",
                    "Но чујте спасителен глас."
                ],
                "refrain": false
            }
        }
    ]
}