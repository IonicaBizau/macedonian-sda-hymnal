{
    "songNumber": 70,
    "title": "Најмило е име Исус",
    "verses": [
        {
            "content": {
                "lines": [
                    "Најмило е име Исус,",
                    "Тоа лечи рани сè,",
                    "Тоа носи мир и радост,",
                    "В срцата на верните."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "(: Колку е сладок глас,",
                    "С кој се слави Исус Спас! :)"
                ],
                "refrain": true
            }
        },
        {
            "content": {
                "lines": [
                    "Најмило е име Исус,",
                    "Кој од грев нè спаси нас,",
                    "И нè води в живот вечен,",
                    "И во него наш е спас."
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Нека секој гласно слави,",
                    "Името на Спасот свој,",
                    "Зашто Бог наш преку него",
                    "Даде спас на родот свој."
                ],
                "refrain": false
            }
        }
    ]
