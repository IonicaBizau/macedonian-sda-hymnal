{
    "songNumber": 30,
    "title": "Божјиот збор е жижок твој",
    "verses": [
        {
            "content": {
                "lines": [
                    "Божјиот Збор е жижок твој,",
                    "Спасот да познаеш",
                    "И љубов која спаси свет",
                    "(:Од страшен тежок грев.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Тој Збор е свет и дава мир,",
                    "По него живеј ти,",
                    "Животот твој сам Господ е,",
                    "(:А друго сè е прав.:)"
                ],
                "refrain": false
            }
        },
        {
            "content": {
                "lines": [
                    "Со вера в него живеј ти",
                    "Во Божја светлина,",
                    "Да бидеш жив на земјата,",
                    "(:Па и во вечноста.:)"
                ],
                "refrain": false
            }
        }
    ]
}